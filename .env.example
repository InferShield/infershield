# ⚠️ PASSTHROUGH MODEL - NO UPSTREAM API KEYS REQUIRED
# 
# InferShield v0.9.0+ uses a passthrough model:
# - Developers send their own LLM API keys in the Authorization header
# - InferShield validates, scans, and forwards requests
# - Upstream keys are NEVER stored, logged, or cached
#
# For local testing of the standalone proxy (proxy/server.js), you may
# optionally set these. For production SaaS deployment, DO NOT SET THESE.
#
# OPENAI_API_KEY=sk-your-openai-key-here  # Required only when KEY_MODE=server or KEY_MODE=auto

# Proxy API Key Mode
# Controls how the proxy handles API keys for upstream LLM requests.
#
#   passthrough (default) — Client supplies their own key in the Authorization header.
#                           No server-side key required. Recommended for all deployments.
#
#   auto                  — Use OPENAI_API_KEY if set; otherwise fall back to the client's
#                           Authorization header. Useful during migration.
#
#   server (DEPRECATED)   — Use the server-side OPENAI_API_KEY exclusively.
#                           Requires OPENAI_API_KEY. A deprecation warning is logged at startup.
#                           Migrate to passthrough mode as soon as possible.
#
KEY_MODE=passthrough

# InferShield Backend
BACKEND_URL=http://localhost:5000

# Proxy Settings
PROXY_PORT=8000

# Security Configuration
RISK_THRESHOLD=70
BLOCK_HIGH_RISK=true

# Logging
LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=90

# ============================================
# Redis Session Store (v0.9.0+)
# ============================================
# Redis enables:
# - Horizontal scaling (multi-instance deployment)
# - Session persistence across restarts
# - Zero session data loss

# Redis Connection (Option 1: URL format - recommended)
# Railway/Upstash/Redis Cloud provide this automatically
# REDIS_URL=redis://user:password@host:port/db
# For TLS (production):
# REDIS_URL=rediss://user:password@host:port/db

# Redis Connection (Option 2: Individual parameters)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-secure-password
# REDIS_DB=0
# REDIS_TLS=false

# Session Configuration
SESSION_TTL=3600                    # Session TTL in seconds (default: 1 hour)
SESSION_CLEANUP_INTERVAL=300000     # Cleanup check interval in ms (default: 5 min)

# Feature Flags
USE_REDIS_SESSIONS=true             # Enable Redis sessions (default: true)
REDIS_FALLBACK_MEMORY=false         # Fallback to in-memory on Redis failure (default: false)

# For local development without Redis:
# USE_REDIS_SESSIONS=false
